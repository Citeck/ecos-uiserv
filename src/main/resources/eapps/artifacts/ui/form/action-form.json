  "definition": {
    "components": [
      {
        "key": "tabs",
        "components": [
          {
            "label": "Main",
            "key": "mainTab",
            "components": [
              {
                "key": "mainPanel",
                "type": "panel",
                "input": false,
                "components": [
                  {
                    "columns": [
                      {
                        "components": [
                          {
                            "label": "Action ID",
                            "key": "id",
                            "validate": {
                              "required": true,
                              "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*$"
                            },
                            "defaultValue": "",
                            "logic": [
                              {
                                "name": "disabled",
                                "trigger": {
                                  "type": "javascript",
                                  "javascript": "result = _.get(instance, 'root.options.formMode') !== 'CREATE';"
                                },
                                "actions": [
                                  {
                                    "name": "setDisabled",
                                    "type": "property",
                                    "property": {
                                      "label": "Disabled",
                                      "value": "disabled",
                                      "type": "boolean"
                                    },
                                    "state": "true"
                                  }
                                ]
                              }
                            ],
                            "type": "textfield",
                            "input": true
                          },
                          {
                            "label": "Action Name",
                            "key": "name",
                            "validate": {
                              "required": true
                            },
                            "type": "mlText",
                            "input": true
                          },
                          {
                            "label": "Plural Name",
                            "key": "pluralName",
                            "type": "mlText",
                            "input": true
                          },
                          {
                            "label": "Action Type",
                            "key": "type",
                            "validate": {
                              "required": true
                            },
                            "data": {
                              "values": [
                                {
                                  "label": "view",
                                  "value": "view"
                                },
                                {
                                  "label": "edit",
                                  "value": "edit"
                                },
                                {
                                  "label": "open-in-background",
                                  "value": "open-in-background"
                                },
                                {
                                  "label": "download",
                                  "value": "download"
                                },
                                {
                                  "label": "delete",
                                  "value": "delete"
                                },
                                {
                                  "label": "download-card-template",
                                  "value": "download-card-template"
                                },
                                {
                                  "label": "download-by-template",
                                  "value": "download-by-template"
                                },
                                {
                                  "label": "view-card-template",
                                  "value": "view-card-template"
                                },
                                {
                                  "label": "upload-new-version",
                                  "value": "upload-new-version"
                                },
                                {
                                  "label": "create",
                                  "value": "create"
                                },
                                {
                                  "label": "save-as-case-template",
                                  "value": "save-as-case-template"
                                },
                                {
                                  "label": "open-url",
                                  "value": "open-url"
                                },
                                {
                                  "label": "assoc-action",
                                  "value": "assoc-action"
                                },
                                {
                                  "label": "content-preview-modal",
                                  "value": "content-preview-modal"
                                },
                                {
                                  "label": "fetch",
                                  "value": "fetch"
                                },
                                {
                                  "label": "view-business-process",
                                  "value": "view-business-process"
                                },
                                {
                                  "label": "cancel-business-process",
                                  "value": "cancel-business-process"
                                },
                                {
                                  "label": "mutate",
                                  "value": "mutate"
                                },
                                {
                                  "label": "edit-menu",
                                  "value": "edit-menu"
                                },
                                {
                                  "label": "view-menu",
                                  "value": "view-menu"
                                },
                                {
                                  "label": "task-outcome",
                                  "value": "task-outcome"
                                },
                                {
                                  "label": "tasks-actions",
                                  "value": "tasks-actions"
                                },
                                {
                                  "label": "edit-password",
                                  "value": "edit-password"
                                },
                                {
                                  "label": "open-submit-form",
                                  "value": "open-submit-form"
                                },
                                {
                                  "label": "user-event",
                                  "value": "user-event"
                                },
                                {
                                  "label": "transform",
                                  "value": "transform"
                                },
                                {
                                  "label": "script",
                                  "value": "script"
                                }
                              ]
                            },
                            "valueProperty": "value",
                            "defaultValue": "",
                            "type": "select",
                            "input": true
                          }
                        ],
                        "type": "column",
                        "input": false,
                        "key": "column",
                        "index": 0
                      },
                      {
                        "index": 1,
                        "type": "column",
                        "input": false,
                        "key": "column",
                        "components": [
                          {
                            "label": "Icon",
                            "key": "icon",
                            "tooltip": {
                              "ru": "Код иконки из шрифта Citeck (например: icon-delete, icon-edit)",
                              "en": "Icon code from Citeck icon font (e.g.: icon-delete, icon-edit)"
                            },
                            "type": "textfield",
                            "input": true
                          },
                          {
                            "label": "Type Reference",
                            "key": "typeRef",
                            "journalId": "ecos-types",
                            "type": "selectJournal",
                            "input": true
                          },
                          {
                            "label": "Pre Action Module",
                            "key": "preActionModule",
                            "tooltip": {
                              "ru": "Ссылка на модуль с JS кодом для предобработки",
                              "en": "Reference to a module with JS code for pre-processing"
                            },
                            "type": "textfield",
                            "input": true
                          }
                        ]
                      }
                    ],
                    "key": "mainColumns",
                    "type": "columns",
                    "input": false
                  }
                ]
              }
            ]
          },
          {
            "label": "Config",
            "key": "configTab",
            "components": [
              {
                "label": "Script config",
                "key": "scriptConfigPanel",
                "customConditional": "show = data.type === 'script';",
                "type": "panel",
                "input": false,
                "components": [
                  {
                    "label": {
                      "ru": "JavaScript функция",
                      "en": "JavaScript Function"
                    },
                    "key": "scriptFnEditor",
                    "tooltip": {
                      "ru": "JavaScript функция для выполнения действия. Доступны переменные: record, context.",
                      "en": "JavaScript function to execute the action. Available variables: record, context."
                    },
                    "editor": "ace",
                    "as": "javascript",
                    "rows": 25,
                    "persistent": false,
                    "refreshOn": [
                      "scriptFnLoaded"
                    ],
                    "calculateValue": "value = _.get(data, 'scriptFnLoaded._config', '') || '';",
                    "allowCalculateOverride": true,
                    "type": "textarea",
                    "input": true
                  },
                  {
                    "label": "scriptFnLoader",
                    "source": {
                      "type": "custom",
                      "custom": {
                        "syncData": "value = { recId: instance.options.recordId };",
                        "asyncData": "return Citeck.Records.get(data.recId).load({'_config': 'config.fn?str'});"
                      },
                      "forceLoad": false
                    },
                    "update": {
                      "type": "once"
                    },
                    "executionCondition": "value = !_.has(data, 'scriptFnLoaded._config') && data.type === 'script';",
                    "key": "scriptFnLoaded",
                    "type": "asyncData",
                    "input": true
                  }
                ]
              },
              {
                "label": {
                  "ru": "Конфигурация (JSON)",
                  "en": "Config (JSON)"
                },
                "key": "configJsonEditor",
                "tooltip": {
                  "ru": "Конфигурация действия в формате JSON. Поля зависят от выбранного типа действия.",
                  "en": "Action configuration in JSON format. Fields depend on the selected action type."
                },
                "editor": "ace",
                "wysiwyg": "",
                "persistent": false,
                "refreshOn": [
                  "configLoaded"
                ],
                "calculateValue": "value = _.get(data, 'configLoaded._config', null);",
                "allowCalculateOverride": true,
                "optionalWhenDisabled": false,
                "customConditional": "show = data.type !== 'script';",
                "rows": 25,
                "as": "json",
                "type": "textarea",
                "input": true,
                "defaultValue": "",
                "uploadStorage": "",
                "uploadUrl": "",
                "uploadOptions": "",
                "uploadDir": "",
                "reorder": false
              },
              {
                "label": "configLoader",
                "source": {
                  "type": "custom",
                  "custom": {
                    "syncData": "value = { recId: instance.options.recordId };",
                    "asyncData": "return Citeck.Records.get(data.recId).load({'_config': 'config?json'});"
                  },
                  "forceLoad": false
                },
                "update": {
                  "type": "once"
                },
                "executionCondition": "value = !_.has(data, 'configLoaded._config') && data.type !== 'script';",
                "key": "configLoaded",
                "type": "asyncData",
                "input": true
              },
              {
                "key": "config",
                "refreshOn": [
                  "scriptFnEditor",
                  "configJsonEditor",
                  "type"
                ],
                "calculateValue": "if (data.type === 'script') { var fn = data.scriptFnEditor; value = (fn === '' || fn === undefined || fn === null) ? null : { fn: fn }; } else { value = data.configJsonEditor || null; }",
                "type": "hidden",
                "input": true
              }
            ]
          },
          {
            "label": "Features",
            "key": "featuresTab",
            "components": [
              {
                "key": "featuresPanel",
                "type": "panel",
                "input": false,
                "components": [
                  {
                    "label": "Applicability",
                    "key": "features",
                    "type": "container",
                    "input": true,
                    "components": [
                      {
                        "key": "featuresColumns",
                        "inlineColumns": true,
                        "columns": [
                          {
                            "components": [
                              {
                                "label": "For Record",
                                "key": "execForRecord",
                                "tooltip": {
                                  "ru": "Действие доступно для одной записи",
                                  "en": "Action is available for a single record"
                                },
                                "hasThreeStates": true,
                                "type": "checkbox",
                                "input": true
                              }
                            ],
                            "md": 4,
                            "type": "column",
                            "input": false,
                            "key": "column",
                            "index": 0
                          },
                          {
                            "md": 4,
                            "type": "column",
                            "input": false,
                            "key": "column",
                            "index": 1,
                            "components": [
                              {
                                "label": "For Records",
                                "key": "execForRecords",
                                "tooltip": {
                                  "ru": "Действие доступно для выбранных записей",
                                  "en": "Action is available for selected records"
                                },
                                "hasThreeStates": true,
                                "type": "checkbox",
                                "input": true
                              }
                            ]
                          },
                          {
                            "md": 4,
                            "type": "column",
                            "input": false,
                            "key": "column",
                            "index": 2,
                            "components": [
                              {
                                "label": "For Query",
                                "key": "execForQuery",
                                "tooltip": {
                                  "ru": "Действие доступно для всего запроса (без выбора записей)",
                                  "en": "Action is available for the entire query (without selecting records)"
                                },
                                "hasThreeStates": true,
                                "type": "checkbox",
                                "input": true
                              }
                            ]
                          }
                        ],
                        "type": "columns",
                        "input": false
                      }
                    ]
                  },
                  {
                    "columns": [
                      {
                        "components": [
                          {
                            "label": "Batch Size",
                            "key": "execForRecordsBatchSize",
                            "tooltip": {
                              "ru": "Размер пакета для обработки нескольких записей",
                              "en": "Batch size for processing multiple records"
                            },
                            "defaultValue": 0,
                            "type": "number",
                            "input": true
                          },
                          {
                            "label": "Parallel Batches Count",
                            "key": "execForRecordsParallelBatchesCount",
                            "tooltip": {
                              "ru": "Количество параллельных пакетов для обработки",
                              "en": "Number of parallel batches for processing"
                            },
                            "defaultValue": 1,
                            "type": "number",
                            "input": true
                          }
                        ],
                        "type": "column",
                        "input": false,
                        "key": "column",
                        "index": 0
                      },
                      {
                        "index": 1,
                        "type": "column",
                        "input": false,
                        "key": "column",
                        "components": [
                          {
                            "label": "Timeout Error Message",
                            "key": "timeoutErrorMessage",
                            "tooltip": {
